# n8n webhook (GET) returning { "customers": [], "invoices": [], "payments": [] }
N8N_WEBHOOK_URL=http://localhost:5678/webhook/02961242-0f97-4942-b90f-bd98372f0369

# ETL: QBO EmailStatus values that set invoices.is_email_sent (case-insensitive, comma-separated).
# Default: Sent,EmailSent,NeedToSend (NeedToSend = queued for email in QBO).
# Strict “only sent in QBO”: QBO_IS_EMAIL_SENT_STATUSES=Sent,EmailSent
# QBO_IS_EMAIL_SENT_STATUSES=Sent,EmailSent,NeedToSend

# Postgres URI: Supabase → Project Settings → Database → Connection string
# Use either DATABASE_URL or SUPABASE_DB_URL (same value).
#
# Transaction pooler (IPv4, port 6543) — copy your exact URI from the dashboard:
# DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-1-ap-south-1.pooler.supabase.com:6543/postgres
#
# Session pooler often uses port 5432 on the same pooler host.
# Direct db.*.supabase.co can fail on IPv4-only networks.
#
# Encode @ in the password as %40
DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-1-ap-south-1.pooler.supabase.com:6543/postgres

# Natural-language Q&A: OpenAI first (gpt-4 default), then Gemini fallback
OPENAI_API_KEY_1=
OPENAI_API_KEY_2=
# OPENAI_MODEL=gpt-4
# OPENAI_PLANNER_MODEL=gpt-4
# OPENAI_SQL_MODEL=gpt-4

# Optional fallback if both OpenAI keys fail (Google AI Studio)
GEMINI_API_KEY=
# Default fallback model is gemini-2.5-flash-lite (avoid deprecated gemini-2.0-flash on free tier)
# GEMINI_MODEL=gemini-2.5-flash
# 429 retries for ask.py (exponential backoff + server retry hint); default 3 extra attempts
# GEMINI_MAX_RETRIES=3
# GEMINI_RETRY_BASE_SECONDS=1
# GEMINI_RETRY_MAX_SLEEP_SECONDS=120
# Optional: plan step model (defaults to GEMINI_MODEL)
# GEMINI_PLANNER_MODEL=gemini-2.5-flash-lite
# One Gemini call + full SQL snapshot (skip planner; larger context to the answer model)
# WAREHOUSE_QA_NO_PLANNER=1

# LLM-generated SELECT + execute + answer (falls back to packs on error). Optional: GEMINI_SQL_MODEL
# WAREHOUSE_QA_DYNAMIC_SQL=1
# Log when dynamic SQL falls back: WAREHOUSE_QA_VERBOSE=1
# Optional: cap prior-turn context injected into Q&A (POST /api/v1/qa "context" array)
# WAREHOUSE_QA_CONTEXT_MAX_CHARS=12000
# WAREHOUSE_QA_CONTEXT_MAX_MESSAGES=24

# Analytics API (python server.py) — metrics, POST /api/v1/sync, POST /api/v1/qa
# Q&A uses the same DATABASE_URL + OPENAI_* / GEMINI_* keys as python ask.py (warehouse_qa).
# PORT=5050
# FLASK_HOST=127.0.0.1
# FLASK_DEBUG=0
# Optional: require X-Sync-Token or Authorization: Bearer for POST /api/v1/sync
# SYNC_API_SECRET=

# Optional overrides
# N8N_HTTP_TIMEOUT_SECONDS=120
# SUPABASE_INSERT_CHUNK_SIZE=500
